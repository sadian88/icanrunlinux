# === Docker Compose variables ===
# Database credentials (used by docker-compose.yml)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=linux_compat
FRONTEND_PORT=80

# === PostgreSQL + pgvector ===
DATABASE_URL=postgresql://user:password@localhost:5432/linux_compat

# Embeddings API (OpenAI-compatible)
EMBEDDINGS_API_URL=https://api.openai.com/v1/embeddings
EMBEDDINGS_API_KEY=sk-your-key-here
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSIONS=1536

# LLM config (DeepSeek via OpenRouter)
# If LLM_API_KEY is not set, it falls back to EMBEDDINGS_API_KEY
LLM_API_URL=https://api.deepseek.com/chat/completions
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek/deepseek-chat

# Similarity threshold for database matches.
# If the best pgvector match is below this value, we fallback to the LLM.
MATCH_THRESHOLD=0.5

# AI cache threshold: minimum cosine similarity to reuse a cached LLM response.
AI_CACHE_THRESHOLD=0.92

# Rate limiting
RATE_LIMIT_MAX=2
RATE_LIMIT_WINDOW=3600

# Security
ALLOWED_ORIGINS=*
MAX_REQUEST_SIZE=10240
